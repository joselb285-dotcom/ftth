# URL del proyecto Supabase (Settings > API > Project URL)
VITE_SUPABASE_URL=https://<project-ref>.supabase.co

# Clave anon/public de Supabase (Settings > API > anon public)
VITE_SUPABASE_ANON_KEY=

# API key de MapTiler para capas Satélite e Híbrido (cloud.maptiler.com → API keys)
# Sin esta clave esas opciones quedan deshabilitadas en el selector de capas
VITE_MAPTILER_KEY=

# Slug del tenant en Supabase (tabla tenants.slug)
# Por defecto usa 'ftth' si no se define
VITE_TENANT_SLUG=ftth
